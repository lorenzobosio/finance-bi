# Finance BI — environment variables (placeholders only; copy to .env.local and fill real values).
# .env.local is git-ignored. NEVER commit real secrets. Only this .env.example is committed.
#
# Key-style note (RESEARCH A3): a new Supabase project may issue new-style
# `sb_publishable_…` / `sb_secret_…` keys instead of the legacy `anon` / `service_role`
# JWT keys. Keep the variable NAMES below as-is and paste whichever key VALUE the
# Supabase dashboard issues (record which style in PROVISIONING.md / the SUMMARY).

# --- Supabase (public — safe to expose to the browser) ---
# Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Project Settings -> API -> anon/public key (or the sb_publishable_ key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-sb_publishable_-key

# --- Supabase (SECRET — SERVER ONLY; never prefix with NEXT_PUBLIC_) ---
# Project Settings -> API -> service_role key (or sb_secret_ key). Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service_role-or-sb_secret_-key

# --- Allowlist (the 2 permitted Google emails, comma-separated, lowercase) ---
ALLOWED_EMAILS=lorenzo@example.com,fernanda@example.com

# --- Drizzle migrations (direct Postgres connection) ---
# Project Settings -> Database -> Connection string -> Session pooler (port 5432).
DATABASE_URL=postgresql://postgres.your-project-ref:[password]@aws-region.pooler.supabase.com:5432/postgres
