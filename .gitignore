.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
!.env.example

# enable banking — saved SCA sessions (session_id + account uids); never commit
.secrets/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# gsd research web-fetch cache (not source)
.planning/research/.cache/
